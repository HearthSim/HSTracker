    "HSTracker needs elevated privileges to read data from Hearthstone's memory. If macOS asks you for your system password, do not be alarmed, no changes to your computer will be performed." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "HSTracker benötigt erweiterte Privilegien um Daten aus dem Speicher von Hearthstone zu lesen. Es werden KEINE ÄNDERUNGEN an Deinem Mac vorgenommen, wenn macOS Dich nach Deinem Systempassword fragt."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "HSTracker needs elevated privileges to read data from Hearthstone's memory. If macOS asks you for your system password, do not be alarmed, no changes to your computer will be performed."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "HSTracker needs elevated privileges to read data from Hearthstone's memory. If macOS asks you for your system password, do not be alarmed, no changes to your computer will be performed."
          }
        },
        "es-MX" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "HSTracker needs elevated privileges to read data from Hearthstone's memory. If macOS asks you for your system password, do not be alarmed, no changes to your computer will be performed."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "HSTracker a besoin de privilèges spéciaux pour lire les données depuis la mémoire de Hearthstone. Si macOS vous demande votre mot de passe système, ne soyez pas alarmés, aucune modification ne sera faite à votre système."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "HSTracker needs elevated privileges to read data from Hearthstone's memory. If macOS asks you for your system password, do not be alarmed, no changes to your computer will be performed."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "HSTracker needs elevated privileges to read data from Hearthstone's memory. If macOS asks you for your system password, do not be alarmed, no changes to your computer will be performed."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "HSTracker는 하스스톤 게임의 메모리를 읽기 위해 특순 권한을 필요로 합니다. 만약 macOS가 시스템 비밀번호를 요구한다는 알람이 뜨더라도 시스템에는 아무런 변경사항이 없습니다."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "HSTracker needs elevated privileges to read data from Hearthstone's memory. If macOS asks you for your system password, do not be alarmed, no changes to your computer will be performed."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "HSTracker requer privilégios elevados para ler dados da memória do Hearthstone. Se o macOS te pedir a senha do sistema, não se preocupe, nenhuma alteração será feita no seu computador."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "HSTracker необходимы повышенные привилегии для чтения данных из памяти Hearthstone. Если macOS запрашивает у вас системный пароль, не беспокойтесь, никакие изменения на вашем компьютере производиться не будут."
          }
        },
        "th-TH" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "HSTracker needs elevated privileges to read data from Hearthstone's memory. If macOS asks you for your system password, do not be alarmed, no changes to your computer will be performed."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "HSTracker 需要您的权限以读取炉石传说的数据。若系统要求您输入密码请不必担心，您电脑中的设置不会被改变。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "HSTracker 需要您的權限以讀取爐石戰記的資料，若系統要求您輸入密碼時請不必擔心，您電腦中的設定將不會被更改。"
          }
        }
      }
    },
